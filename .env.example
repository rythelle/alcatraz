# Copy this file to .env and adjust the values.
# docker-compose reads .env automatically.

# Docker Compose project name (sets the container name prefix)
COMPOSE_PROJECT_NAME=alcatraz

# API keys - pick your provider (opencode supports multiple backends)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# GOOGLE_API_KEY=...
# OPENCODE_API_KEY=...

# Mega Brain memory vault path on the host.
# Default (if unset): ./.ai-context (local folder, created automatically).
# To sync with Obsidian/OneDrive, point this at your vault, e.g.:
#   Windows via WSL2: /mnt/c/Users/{user}/OneDrive/Documents/AIContext
#   Native Linux:     /home/{user}/Documents/AIContext
#   macOS:            /Users/{user}/Documents/AIContext
AI_CONTEXT_PATH=./.ai-context

# Node.js version (must be supported by NVM)
NODE_VERSION=22.19

# Optional Mega Brain prefix grouping. Set both to route repos whose name starts
# with the prefix into a vault subfolder (e.g. acme-web -> {vault}/Acme/acme-web).
MEGABRAIN_GROUP_PREFIX=
MEGABRAIN_GROUP_DIR=

# Extra projects to mount in the container (comma-separated).
# Each path is mounted at /workspace/projects/<folder-name>. Example:
# PROJECT_PATHS=/home/your-user/my-project,/home/your-user/another-project
PROJECT_PATHS=
